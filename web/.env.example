# Web app (set these in Vercel project env vars too)
SUPABASE_URL=https://YOUR-REF.supabase.co
SUPABASE_KEY=YOUR-ANON-PUBLIC-KEY      # anon key only - never the service key here

# Server-only connector fabric. Use a long random value and keep it stable.
CONNECTOR_VAULT_KEY=replace-with-at-least-32-random-bytes

# OAuth applications; callback URL is https://YOUR-HOST/api/connectors/oauth/callback
GOOGLE_CONNECTOR_CLIENT_ID=
GOOGLE_CONNECTOR_CLIENT_SECRET=
MICROSOFT_CONNECTOR_CLIENT_ID=
MICROSOFT_CONNECTOR_CLIENT_SECRET=
GITHUB_CONNECTOR_CLIENT_ID=
GITHUB_CONNECTOR_CLIENT_SECRET=
SLACK_CONNECTOR_CLIENT_ID=
SLACK_CONNECTOR_CLIENT_SECRET=
ATLASSIAN_CONNECTOR_CLIENT_ID=
ATLASSIAN_CONNECTOR_CLIENT_SECRET=
NOTION_CONNECTOR_CLIENT_ID=
NOTION_CONNECTOR_CLIENT_SECRET=

# Optional fallback for MCP authorization servers without dynamic client registration.
MCP_CONNECTOR_CLIENT_ID=
MCP_CONNECTOR_CLIENT_SECRET=
