{
  "installCommand": "npm ci --ignore-scripts --prefer-offline --no-audit --no-fund",
  "git": {
    "deploymentEnabled": {
      "*": false,
      "master": true
    }
  },
  "ignoreCommand": "git diff --quiet HEAD^ HEAD -- . ../packages/darwin-kernel",
  "crons": [
    {
      "path": "/api/fleet/analytics?rangeDays=1&sync=true",
      "schedule": "0 6 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://*.vercel.app"
        }
      ]
    }
  ]
}
