# Fleet Admin Control Plane — Orchestrator env wiring.
# Copy the relevant vars into the Orchestrator web project's env (Vercel + local .env).

# Supabase (service role — the plane is trusted infra; RLS protects the dashboard)
SUPABASE_URL=https://eatfwdzfurujcuwlhdgj.supabase.co
SUPABASE_SERVICE_KEY=__set_me__

# This deployment's public base URL (used to build the Smarter callback URL)
ORCHESTRATOR_BASE_URL=https://claude-orchestrator.vercel.app

# Shared secret authenticating plane <-> app and plane <-> Smarter calls (any long random string)
FLEET_SHARED_SECRET=__set_me_same_value_in_every_app__

# Where the plane mirrors approval cards (Bear's Smarter inbox)
SMARTER_INBOX_URL=https://<smarter-domain>/api/fleet/inbox

# Per-app execute endpoints the plane delegates to (adapter server side).
# The plane never touches an app DB directly — it POSTs {action} to <base>/api/fleet/execute.
FLEET_URL_APPARENTLY=https://___your_apparently_vercel_url___
FLEET_URL_TOMORROW=https://___your_tomorrow_vercel_url___
FLEET_URL_SMARTER=https://smarter-nine.vercel.app
FLEET_URL_GALOP=https://___your_galop_console_vercel_url___
FLEET_URL_HISANTA=https://admin-portal-nine-ochre.vercel.app
FLEET_URL_PARETO=https://___your_pareto_vercel_url___
# Sustainable Barks / darwn / new apps: add FLEET_URL_<PRODUCT> as they onboard.

# ── Per-app Supabase credentials (proxy layer) ──────────────────────────
# Each app's service-role key, used by the proxy API to query any app's data.
SUPABASE_URL_APPARENTLY=https://___your_apparently_project___.supabase.co
SUPABASE_SERVICE_KEY_APPARENTLY=__set_me__
SUPABASE_URL_TOMORROW=https://___your_tomorrow_project___.supabase.co
SUPABASE_SERVICE_KEY_TOMORROW=__set_me__
SUPABASE_URL_SMARTER=https://olaxnyrzoptjcntrrjgn.supabase.co
SUPABASE_SERVICE_KEY_SMARTER=__set_me__
SUPABASE_URL_GALOP=https://qlzsnuspiypyejaqcdad.supabase.co
SUPABASE_SERVICE_KEY_GALOP=__set_me__
SUPABASE_URL_HISANTA=https://whhfugddqehxxbmwutsw.supabase.co
SUPABASE_SERVICE_KEY_HISANTA=__set_me__
SUPABASE_URL_PARETO=https://___your_pareto_project___.supabase.co
SUPABASE_SERVICE_KEY_PARETO=__set_me__

# ── OPS_EMAILS (auth middleware allowlist) ────────────────────────────────
OPS_EMAILS=kalepasch@gmail.com,kale@smrter.us

# ── Each app needs these in THEIR env for fleet integration ──────────────
# FLEET_SHARED_SECRET=<same value as orchestrator>
# ORCHESTRATOR_INGEST_URL=https://web-six-chi-76.vercel.app/api/fleet/ingest
