    "chart.js": "^4.5.1",
    "nuxt": "3.21.8",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@nuxtjs/supabase": "1.5.3",
    "@nuxtjs/tailwindcss": "^6.12.0",
    "@types/node": "^26.1.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "typescript": "6.0.3",
    "vitest": "^4.1.0",
    "vue-tsc": "3.3.6"
