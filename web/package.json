    "pretest": "npm run verify:deps && npm run verify:navigation && npm run verify:journeys && npm run verify:experience",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "test": "vitest",
    "typecheck": "vue-tsc --noEmit",
    "verify:deps": "node scripts/verify-dependency-graph.mjs",
    "verify:navigation": "node scripts/verify-navigation-contract.mjs",
    "verify:journeys": "node scripts/verify-journey-contracts.mjs",
    "verify:embeds": "node scripts/verify-embed-contracts.mjs",
    "verify:experience": "node scripts/verify-experience-contracts.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@darwin/kernel": "file:../packages/darwin-kernel",
    "@nuxt/cli": "3.36.1",
