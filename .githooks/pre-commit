#!/bin/bash
# pre-commit hook - prevent committing machine-specific settings files

# Check if .claude/settings.local.json is being staged
if git diff --cached --name-only | grep -q "\.claude/settings.local.json"; then
    echo "ERROR: .claude/settings.local.json is machine-specific and should NEVER be committed."
    echo "This file contains overly permissive allowlists that create a security regression."
    echo ""
    echo "To fix:"
    echo "  1. Unstage it: git reset HEAD .claude/settings.local.json"
    echo "  2. Verify .gitignore has the entry (already does)"
    echo "  3. Continue with your commit"
    exit 1
fi

# Check for other machine-specific files
for pattern in ".env.local" "settings.local.json"; do
    if git diff --cached --name-only | grep -q "$pattern"; then
        echo "WARNING: File matching '$pattern' is being committed. Verify this is intentional."
    fi
done

# Enforce canonical git author to prevent Vercel BLOCKED deployments
AUTHOR_EMAIL=$(git config user.email)
CANONICAL_EMAIL="kalepasch@gmail.com"
if [ "$AUTHOR_EMAIL" != "$CANONICAL_EMAIL" ]; then
    echo "ERROR: Git author email is '$AUTHOR_EMAIL' but must be '$CANONICAL_EMAIL'"
    echo "Vercel will BLOCK deployments from non-canonical authors."
    echo ""
    echo "Fix with: git config user.email \"$CANONICAL_EMAIL\""
    echo "          git config user.name \"kalepasch1\""
    exit 1
fi

exit 0
