<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- TEMPLATE — run scripts/setup-scheduler.sh to install.
     Runs nightly at 11 PM with INTEGRATION_MODE=pr (7 hour timeout). -->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.claudeorchestrator.overnight-deploy</string>
    <key>ProgramArguments</key>
    <array>
        <string>__APP_DIR__/Contents/MacOS/ClaudeRunner</string>
        <string>runner.py</string>
    </array>
    <key>EnvironmentVariables</key>
    <dict>
        <key>INTEGRATION_MODE</key>
        <string>pr</string>
        <key>MAX_PARALLEL</key>
        <string>MAX_PARALLEL_PLACEHOLDER</string>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>
    <key>WorkingDirectory</key>
    <string>REPO_PATH/runner</string>
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>23</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>
    <key>StandardOutPath</key>
    <string>LOG_DIR/overnight-deploy.log</string>
    <key>StandardErrorPath</key>
    <string>LOG_DIR/overnight-deploy.err</string>
</dict>
</plist>
