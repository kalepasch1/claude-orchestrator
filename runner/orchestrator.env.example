# ────────────────────────────────────────────────────────────────────────────
# Orchestrator model defaults — the "source of truth" Claude Code + the runner agree on.
# Merge these into runner/.env (keep your existing SUPABASE_URL + SUPABASE_SERVICE_KEY).
# This file is a TEMPLATE with NO secrets — fill the blank keys yourself.
# ────────────────────────────────────────────────────────────────────────────

# ── Cost mode: use the Max SUBSCRIPTION login ($0/call), NOT prepaid API billing.
#    (Leaving ANTHROPIC_API_KEY set + this true = subscription is used; API is dropped.)
ORCH_USE_SUBSCRIPTION=true

# ── Opus-retune: default cheap, escalate only when needed (fixes the token burn).
ORCH_DEFAULT_MODEL=claude-haiku-4-5-20251001      # ~everything starts here
ORCH_ESCALATION_MODEL=claude-sonnet-4-6           # on retry / standard complexity
ORCH_HARD_MODEL=claude-opus-4-8                   # ONLY hard/security/legal or after escalation
ORCH_OPUS_MAX_SHARE=0.10                          # alert if Opus exceeds 10% of tasks

# ── Costless-first: proactive spend loops OFF; only run on queued ROI work + real emergencies.
ENABLE_PROACTIVE_LOOPS=false

# ── Hard money caps (circuit breaker in claude_cli — a bug can never exceed these).
CLAUDE_MAX_USD_PER_DAY=40
CLAUDE_MAX_USD_PER_HOUR=10
CLAUDE_MAX_CALLS_PER_HOUR=80

# ── Multi-model providers. Leave BLANK to disable; fill to enable. Gateway auto-detects.
#    (ChatGPT Plus/Premium is NOT API — OPENAI_API_KEY is a separate paid key.)
DEEPSEEK_API_KEY=
GOOGLE_API_KEY=                                   # rotate the one you pasted in chat; use an AIza… key
OPENAI_API_KEY=
OLLAMA_HOST=http://localhost:11434                # free local QA/review/rating
OLLAMA_MODEL=qwen2.5-coder:7b                     # good cheap code reviewer
GEMINI_MODEL=gemini-2.0-flash

# ── Cross-model QA panel size (judges per diff, different family than the author).
JUDGE_PANEL_SIZE=2

# ── Optional HSM-backed provider access. The web runtime consumes these values.
#    Brokered provider credentials are signed, leased for <=15 minutes, and never persisted.
CONNECTOR_CREDENTIAL_BROKER_URL=
CONNECTOR_CREDENTIAL_BROKER_TOKEN=
CONNECTOR_CREDENTIAL_BROKER_PUBLIC_KEY=
CONNECTOR_HSM_SIGNER_URL=
CONNECTOR_HSM_SIGNER_TOKEN=
# Preferred broker authentication: a platform-issued, <=15 minute workload JWT.
CONNECTOR_WORKLOAD_IDENTITY_TOKEN_FILE=
CONNECTOR_WORKLOAD_IDENTITY_AUDIENCE=provider-credential-broker
CONNECTOR_WORKLOAD_IDENTITY_ISSUERS=
CONNECTOR_ALLOW_LEGACY_BROKER_TOKEN=false
# Shared deployment pepper for schema-name HMACs; rotate by privacy epoch.
FEDERATED_MAPPING_PEPPER=
SECURE_MAPPING_AGGREGATOR_PUBLIC_KEY=
SECURE_MAPPING_AGGREGATOR_KEY_ID=
SECURE_MAPPING_AGGREGATOR_ATTESTATION_KEY=
SECURE_MAPPING_THRESHOLD_REQUIRED=true
SECURE_MAPPING_THRESHOLD_KEYS_JSON={}
SECURE_MAPPING_ZK_REQUIRED=true
PROVIDER_ROUTE_MAX_FAILURE_RATE=0.15
PROVIDER_ROUTE_MAX_RISK_SCORE=0.25
PROVIDER_ROUTE_EXPLORATION_RATE=0.05
PROVIDER_QUOTE_BROKER_URL=
CONNECTOR_TEE_REQUIRED=true
CONNECTOR_TEE_ATTESTATION_PUBLIC_KEY=
CONNECTOR_TEE_ALLOWED_MEASUREMENTS=
WASM_ADAPTER_SANDBOX_URL=
WASM_SANDBOX_ATTESTATION_PUBLIC_KEY=
REGULATORY_AUTHORITY_ORIGINS=

# ── Auto-merge rollout is controlled in the DB (projects.auto_merge). tomorrow=ON first.
