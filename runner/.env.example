# Runner (on your Mac) - keep this file private; it holds the SERVICE key.
SUPABASE_URL=https://YOUR-REF.supabase.co
SUPABASE_SERVICE_KEY=YOUR-SERVICE-ROLE-KEY   # secret; bypasses RLS; Mac only

MAX_PARALLEL=2
POLL_SECONDS=5
TEST_CMD="npm test"

# optional: semantic knowledge reuse (else keyword fallback)
EMBED_PROVIDER=                # voyage | openai | (blank)
# VOYAGE_API_KEY=...
# OPENAI_API_KEY=...

# optional: extra authorized accounts for auto-switch on exhaustion
# configure in Supabase `accounts` table or ~/.claude-orchestrator/accounts.json

# ── Confidence-gated autonomy (feature 2) ──────────────────────────────────
# CONFIDENCE_THRESHOLD=0.8          # global default; override per-project in DB
# (per-project: set projects.confidence_threshold in Supabase)

# ── Mutation + property testing (feature 5) ────────────────────────────────
# MUTATION_CMD="npx stryker run"    # run mutation tests; leave blank to skip
# PROPERTY_CMD="npm run test:prop"  # run property tests; leave blank to skip
# MUTATION_MIN_SCORE=60             # fail if mutation score below this %

# ── Canary / metric-gated deploy (feature 4) ───────────────────────────────
# METRICS_URL=https://your-metrics-endpoint/snapshot   # JSON: {error_rate, p95_ms, conversion}
# CANARY_MAX_ERROR_RATE=1.0         # % e.g. 1.0 = 1%
# CANARY_MAX_P95_MS=500
# CANARY_MIN_CONVERSION=2.5
# STAGING_BRANCH=staging
# MAIN_BRANCH=main

# ── Preference learning (feature 6) ────────────────────────────────────────
# PREF_SUPPRESS_BELOW=0.25          # suppress proposals with predicted approval < 25%

# ── Chaos drills (feature 12) ──────────────────────────────────────────────
# CHAOS_ENABLED=true                # ONLY set true on staging / non-prod runners

# ── NL analytics edge function (feature 11) + Batch API (off-peak) ─────────
# ANTHROPIC_API_KEY=sk-ant-...      # edge function `ask` + Batch API (direct HTTP)

# ── Batch API off-peak passes ───────────────────────────────────────────────
# BATCH_MODEL=claude-haiku-4-5-20251001    # model for batch tasks
# BATCH_MAX_TOKENS=4096                    # max output tokens per batch request
# (Queue tasks with kind='batch' in the dashboard — submitted nightly at 23:30)

# ── Supabase branch digital-twin (per-PR preview) ───────────────────────────
# SUPABASE_ACCESS_TOKEN=sbp_...     # personal access token (not service role)
# SUPABASE_PROJECT_REF=eatfwdzfurujcuwlhdgj
# VERCEL_TOKEN=...                  # for updating preview env vars
# VERCEL_PROJECT_ID=...             # Vercel project ID

# ── Embeddings — two-provider strategy ────────────────────────────────────────
# EMBED_PROVIDER controls knowledge_embed + capability dedup + radar (quality-sensitive).
# CONTEXT_EMBED_PROVIDER controls context_retrieval repo-file ranking (high-volume, cost-sensitive).
# Recommended: EMBED_PROVIDER=voyage (quality), CONTEXT_EMBED_PROVIDER=openai (cheap bulk).
# Leave blank to fall back to keyword/LLM paths everywhere.
#
# EMBED_PROVIDER=voyage             # voyage | openai | (blank = keyword/LLM fallback)
# CONTEXT_EMBED_PROVIDER=openai     # openai | voyage | (blank = same as EMBED_PROVIDER)
# OPENAI_API_KEY=sk-...
# VOYAGE_API_KEY=pa-...
# VOYAGE_EMBEDDING_MODEL=voyage-3-large    # default: voyage-3; voyage-3-large is recommended
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small   # default; cheapest OpenAI embedding model
# CAP_DEDUP_THRESHOLD=0.95          # cosine similarity floor for near-duplicate warning

# ── Demand mining source ────────────────────────────────────────────────────
# REQUESTS_FILE=/path/to/requests.txt   # newline-delimited user request strings
# (alternative: insert rows into the `requests` table: project, text, source, created_at)
# DEMAND_MIN=5                          # minimum (privacy-preserved) count to file a proposal

# ── Runtime paths ───────────────────────────────────────────────────────────
# CLAUDE_BIN=claude                     # path to Claude Code CLI (default: claude in PATH)
# (set if claude is not in the launchd PATH, e.g. CLAUDE_BIN=/opt/homebrew/bin/claude)

# ── Virtual executive provider adapters ────────────────────────────────────
# External HR, payroll, banking, tax, legal, compliance, accounting, security,
# procurement, calendar, storage, and email effects are disabled unless a signed
# adapter is configured. The adapter must implement docs/BUSINESS_AGENT_ADAPTER.md.
# FLEET_SHARED_SECRET=...                # required adapter authentication secret
# BUSINESS_AGENT_ADAPTER_URL=https://business-adapter.internal
# Optional per-provider override (provider name is uppercased):
# BUSINESS_AGENT_BANKING_URL=https://banking-adapter.internal
# BUSINESS_AGENT_PAYROLL_URL=https://payroll-adapter.internal
# BUSINESS_AGENT_TAX_URL=https://tax-adapter.internal
# BUSINESS_AGENT_HRIS_URL=https://hris-adapter.internal
# ORCHESTRATOR_WEB_URL=https://orchestrator.example.com  # built-in signed provider gateway fallback
