# Runner (on your Mac) - keep this file private; it holds the SERVICE key.
SUPABASE_URL=https://YOUR-REF.supabase.co
SUPABASE_SERVICE_KEY=YOUR-SERVICE-ROLE-KEY   # secret; bypasses RLS; Mac only

MAX_PARALLEL=2
POLL_SECONDS=5
TEST_CMD="npm test"

# optional: semantic knowledge reuse (else keyword fallback)
EMBED_PROVIDER=                # voyage | openai | (blank)
# VOYAGE_API_KEY=...
# OPENAI_API_KEY=...

# optional: extra authorized accounts for auto-switch on exhaustion
# configure in Supabase `accounts` table or ~/.claude-orchestrator/accounts.json
